    "app/api/cron/hostel-data-retention/route.ts": { "maxDuration": 60 },
    "app/api/notifications/reminders/route.ts":    { "maxDuration": 60 },
    "app/api/cron/notifications/route.ts":         { "maxDuration": 60 },
