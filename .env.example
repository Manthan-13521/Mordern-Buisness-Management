# ── Core ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname
NEXT_PUBLIC_APP_URL=https://yourapp.com
NEXTAUTH_URL=https://yourapp.com

# Generate with: openssl rand -base64 64
NEXTAUTH_SECRET=

# ── Security ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 (must be at least 32 characters)
SEED_SECRET=
SEED_ENABLED=false  # ⚠️  Never set to true in production — allows database seeding
CRON_SECRET=

# ── Cloudinary (photo & QR storage) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Twilio (WhatsApp reminders) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Razorpay (Online payments) ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Webhook secret from Razorpay dashboard (must be at least 20 characters)
RAZORPAY_WEBHOOK_SECRET=

# ── Super Admin Seed ───────────────────────────────────────────────────
# Credentials for the platform superadmin (seeded via /api/seed)
SUPER_ADMIN_EMAIL=superadmin@yourapp.com
SUPER_ADMIN_PASSWORD=

# ── Upstash Redis (rate limiting, caching — optional for dev) ──────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AWS S3 (Database Backups) ─────────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# ── Sentry (Error Tracking) ───────────────────────────────────────────
# Get your DSN from: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Required for source-map upload in CI/CD (not needed for local dev):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ── Load Testing (DANGER — dev/staging only) ──────────────────────────
# ⚠️  WARNING: Setting LOAD_TEST=true disables rate limiting for allowed IPs.
# ⚠️  NEVER set to "true" in production (env.ts will throw on startup).
# ⚠️  Requires LOAD_TEST_SECRET header + IP in LOAD_TEST_ALLOWED_IPS.
LOAD_TEST=false
LOAD_TEST_SECRET=
LOAD_TEST_ALLOWED_IPS=127.0.0.1,::1

