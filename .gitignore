# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
next-dev.log

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
.env*.local

# vercel
.vercel
vercel_logs.json

# typescript
*.tsbuildinfo
next-env.d.ts

# project-specific
/logs/
/backups/
/public/uploads/
/public/exports/
test-*.js
test-*.ts
fix-*.js
fix_*.js
fix_*.py
tester.js
check-*.js
.gitignore-additions.txt
.keep
scratch/

# Debug/fix scripts — never commit these
script-*.js
script-*.py
safe_*.py
revert_*.py
invoice.html

# Logs and temp
*.log
next-dev.log
pw-extract-temp/

# ── Repo hygiene: permanently block debug artifacts ──────────────────
/*.py
/test-*.ts
/test-*.js
.planning/
.agent/
